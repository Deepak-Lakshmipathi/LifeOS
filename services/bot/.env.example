# LifeOS bot secrets — copy to .env (gitignored) and fill in. Never commit real values.

# Telegram Bot API token, issued by @BotFather when you create the bot.
TELEGRAM_BOT_TOKEN=

# Fine-grained GitHub PAT scoped to the vault repo only (Contents: Read + Write).
# Separate credential from the PWA's VITE_VAULT_PAT so the two surfaces can be
# rotated/revoked independently (ADR-0011, Decision 2).
BOT_VAULT_PAT=

# Anthropic API key used for Claude NLU (intent classification + extraction).
ANTHROPIC_API_KEY=

# The single Telegram chat id the bot serves — every other chat id is ignored
# outright (no reply, no vault write, no Claude call).
OWNER_TELEGRAM_CHAT_ID=
