# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Databases (regenerable from seed)
*.db
*.sqlite
*.sqlite3

# Secrets — never commit
.env
.*_token

# Local harness/editor config
.claude/settings.local.json
.idea/
.gradle/
local.properties

# OS
Thumbs.db
.DS_Store

# afk-pipeline intermediate issue bodies (canonical = GitHub issues)
afk-pipeline-out/_*

# Node / Vite
node_modules/
dist/
.vite/

# services/bot — Node git transport's local vault working copy (S16c).
# Never commit: contains a real clone of the vault repo + git history.
.vault-clone/

# Playwright / Lighthouse artifacts
test-results/
playwright-report/
.lighthouseci/
.lh.json
lh.json

# graphify internal (machine-specific paths + regenerable cache)
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/cache/
