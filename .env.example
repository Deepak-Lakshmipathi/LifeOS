# LifeOS PWA vault-mode config — copy to .env (gitignored) and fill in.
# Vault mode is on when you run with VITE_VAULT=1 (e.g. `VITE_VAULT=1 npm run dev`).
# Never commit real values.

# Remote vault repo URL (required). Same repo the bot's BOT_VAULT_REPO_URL points at.
# e.g. https://github.com/<owner>/<vault-repo>.git
VITE_VAULT_REPO_URL=

# Fine-grained GitHub PAT scoped to the vault repo only, Contents: Read + Write
# (write needs push, not just clone/pull). Separate credential from the bot's
# BOT_VAULT_PAT so they rotate independently. Optional; NEVER logged.
VITE_VAULT_PAT=

# CORS proxy (required for browser git against GitHub — github.com sends no CORS
# headers). Public default below, or self-host isomorphic-git/cors-proxy.
VITE_VAULT_CORS_PROXY=https://cors.isomorphic-git.org
